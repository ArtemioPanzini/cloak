{
  "name": "prelander-scoring-gate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Source-agnostic pre-lander anti-automation and interaction-quality scoring gate.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:tail": "tsx src/scripts/tail-audit.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/formbody": "^8.0.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
